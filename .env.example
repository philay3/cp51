# Salt used to hash defendant names for privacy by construction.
# Set this to a long, random, secure string. Do not commit the actual .env file.
DEFENDANT_HASH_SALT=your_long_random_secure_salt_here

# Acquisition layer politeness delays (in seconds)
MIN_DELAY=2.0
MAX_DELAY=5.0

# Database paths (optional overrides, defaults to data/processed/phl.db)
DATABASE_PATH=data/processed/phl.db
